generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [pgcrypto, postgis]
}

enum UserRole {
  ADMIN
  STAFF
  OWNER
  PROVIDER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  phone         String    @unique // Encrypted at application layer
  passwordHash  String    @map("password_hash")
  role          UserRole
  status        UserStatus @default(PENDING_VERIFICATION)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at") // Keep this from previous implementation
  deletedAt     DateTime? @map("deleted_at")
  
  sessions        Session[]
  ownerProfile     OwnerProfile?
  providerProfile  ProviderProfile?

  @@index([role, status])
  @@map("users")
}

model OwnerProfile {
  id        String @id @default(uuid())
  userId    String @unique @map("user_id")
  user      User   @relation(fields: [userId], references: [id])
  firstName String @map("first_name")
  lastName  String @map("last_name")
  
  properties Property[]

  @@map("owner_profiles")
}

model Property {
  id        String   @id @default(uuid())
  ownerId   String   @map("owner_id")
  name      String
  encryptedAddress String @map("encrypted_address") // Updated to match isolation requirements
  location    Unsupported("geometry(Point, 4326)")? // For findBestProvider queries
  latitude    Float
  longitude   Float
  imageUrls String[] @map("image_urls")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner OwnerProfile @relation(fields: [ownerId], references: [id])
  units Unit[]

  @@map("properties")
}

enum UnitType {
  APARTMENT
  HOUSE
  COMMERCIAL
}

model Unit {
  id            String   @id @default(uuid())
  propertyId    String   @map("property_id")
  unitName      String   @map("unit_name")
  unitType      UnitType @map("unit_type")
  squareFootage Float    @map("square_footage")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("units")
}

model ServiceType {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String
  basePrice    Decimal  @map("base_price") @db.Decimal(10, 2)
  pricingRules Json     @map("pricing_rules")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("service_types")
}

model ProviderProfile {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  user              User     @relation(fields: [userId], references: [id])
  businessName      String   @map("business_name")
  serviceCategories String[] @map("service_categories")
  operationalZones  String[] @map("operational_zones")
  
  @@map("provider_profiles")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}